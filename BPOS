<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lucky Bee POS</title>

<style>

body{
font-family:Arial;
margin:0;
background:#0f172a;
color:white;
}

header{
background:#facc15;
color:black;
padding:15px;
display:flex;
justify-content:space-between;
}

.container{
max-width:900px;
margin:auto;
padding:20px;
}

.card{
background:#1e293b;
padding:20px;
border-radius:10px;
margin-bottom:20px;
}

input{
padding:8px;
margin:5px;
border-radius:6px;
border:none;
}

button{
padding:8px 14px;
margin:5px;
border:none;
border-radius:6px;
background:#22c55e;
color:white;
cursor:pointer;
}

footer{
text-align:center;
padding:15px;
background:#020617;
}

.login{
max-width:400px;
margin:60px auto;
text-align:center;
}

#inventory div,#cart div{
padding:6px;
border-bottom:1px solid #334155;
}

</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

</head>

<body>

<div id="loginPage">

<div class="card login">

<h2>🐝 Lucky Bee POS</h2>

<input id="user" placeholder="Username">
<input id="pass" type="password" placeholder="Password">

<br>

<button onclick="login()">Login</button>

<p>Admin: admin / 1234<br>Cashier: cashier / 1111</p>

</div>

</div>

<div id="app" style="display:none">

<header>

<b>Lucky Bee POS</b>

<button onclick="logout()">Logout</button>

</header>

<div class="container">

<div class="card">

<h3>Dashboard</h3>

<p>Total Money: K <span id="money">0</span></p>
<p>Items Sold: <span id="sales">0</span></p>
<p>Total Products: <span id="products">0</span></p>

<canvas id="chart"></canvas>

</div>

<div class="card" id="adminPanel" style="display:none">

<h3>Add Product</h3>

<input id="pname" placeholder="Name">
<input id="pprice" placeholder="Price">
<input id="pstock" placeholder="Stock">

<label><input type="checkbox" id="notForSale"> Not for sale</label>

<br>

<button onclick="addProduct()">Add</button>

</div>

<div class="card">

<input id="search" placeholder="Search product" onkeyup="render()">

</div>

<div class="card">

<h3>Inventory</h3>

<div id="inventory"></div>

</div>

<div class="card" id="cartPanel">

<h3>Cart</h3>

<div id="cart">Cart empty</div>

<button onclick="checkout()">Checkout</button>

</div>

<div class="card">

<h3>Receipt</h3>

<div id="receipt"></div>

<button onclick="printReceipt()">Print</button>

</div>

</div>

<footer>

All rights reserved © Lucky Bee POS

</footer>

</div>

<script>

let products=JSON.parse(localStorage.getItem("products"))||[]
let sales=JSON.parse(localStorage.getItem("sales"))||[]
let cart=[]
let user=null

function login(){

let u=document.getElementById("user").value
let p=document.getElementById("pass").value

if(u=="admin" && p=="1234"){
user="admin"
document.getElementById("adminPanel").style.display="block"
document.getElementById("cartPanel").style.display="none"
}

else if(u=="cashier" && p=="1111"){
user="cashier"
}

else{
alert("Wrong login")
return
}

document.getElementById("loginPage").style.display="none"
document.getElementById("app").style.display="block"

render()
updateDashboard()

}

function logout(){

localStorage.setItem("products",JSON.stringify(products))
localStorage.setItem("sales",JSON.stringify(sales))

location.reload()

}

function addProduct(){

let name=document.getElementById("pname").value
let price=Number(document.getElementById("pprice").value)
let stock=Number(document.getElementById("pstock").value)
let notSale=document.getElementById("notForSale").checked

products.push({id:Date.now(),name,price,stock,notSale})

localStorage.setItem("products",JSON.stringify(products))

render()

}

function addCart(id){

let p=products.find(x=>x.id==id)

if(p.stock<=0||p.notSale){
alert("Not available")
return
}

let item=cart.find(c=>c.id==id)

if(item){
item.qty++
}
else{
cart.push({id:p.id,name:p.name,price:p.price,qty:1})
}

render()

}

function removeCart(id){

cart=cart.filter(c=>c.id!=id)

render()

}

function checkout(){

if(cart.length==0){
alert("Cart empty")
return
}

let receipt=""
let total=0

cart.forEach(c=>{

let p=products.find(x=>x.id==c.id)

p.stock-=c.qty

let cost=c.qty*p.price

total+=cost

sales.push({...c,time:new Date().toLocaleString()})

receipt+=c.name+" x"+c.qty+" = K"+cost+"<br>"

})

receipt+="<br>Total = K"+total

document.getElementById("receipt").innerHTML=receipt

cart=[]

localStorage.setItem("products",JSON.stringify(products))
localStorage.setItem("sales",JSON.stringify(sales))

render()
updateDashboard()

}

function render(){

let search=document.getElementById("search").value.toLowerCase()

let html=""

products.filter(p=>p.name.toLowerCase().includes(search))
.forEach(p=>{

let warn=p.stock<=5?" ⚠ Low Stock":""

let btn=user=="cashier"?`<button onclick="addCart(${p.id})">Add</button>`:""

html+=`<div>${p.name} K${p.price} Stock:${p.stock}${warn} ${btn}</div>`

})

document.getElementById("inventory").innerHTML=html

document.getElementById("cart").innerHTML=
cart.length==0?"Cart empty":
cart.map(c=>`${c.name} x${c.qty} <button onclick="removeCart(${c.id})">Remove</button>`).join("")

updateDashboard()

}

function updateDashboard(){

let money=0
let items=0

sales.forEach(s=>{

money+=s.price*s.qty
items+=s.qty

})

document.getElementById("money").innerText=money
document.getElementById("sales").innerText=items
document.getElementById("products").innerText=products.length

drawChart()

}

function drawChart(){

let ctx=document.getElementById("chart").getContext("2d")

let data=sales.map(s=>s.price*s.qty)

let labels=sales.map(s=>s.time)

if(window.chart)window.chart.destroy()

window.chart=new Chart(ctx,{
type:"line",
data:{labels:labels,datasets:[{label:"Sales",data:data,borderColor:"yellow"}]}
})

}

function printReceipt(){

let w=window.open()

w.document.write(document.getElementById("receipt").innerHTML)

w.print()

}

</script>

</body>
</html>
